              "api-reference/endpoint/get-api-v1-einvoice-resources-invoices-types",
              "api-reference/endpoint/get-api-v1-einvoice-resources-lgas",
              "api-reference/endpoint/get-api-v1-einvoice-resources-payment-means",
              "api-reference/endpoint/get-api-v1-einvoice-resources-products",
              "api-reference/endpoint/get-api-v1-einvoice-resources-services",
              "api-reference/endpoint/get-api-v1-einvoice-resources-states",
              "api-reference/endpoint/get-api-v1-einvoice-resources-tax-categories",
              "api-reference/endpoint/get-api-v1-einvoice-resources-units-of-measurement"
            ]
          },
          {
            "group": "IRN and QR",
