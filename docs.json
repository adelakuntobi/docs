  },
  "stylesheets": [
    "/custom.css"
  ],
  "navbar": {},
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
