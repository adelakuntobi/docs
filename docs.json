{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PASCA API Documentation",
  "colors": {
    "primary": "#0061FE",
    "light": "#0061FE",
    "dark": "#0061FE"
  },
  "favicon": "/logo/light.svg",
  "api": {
    "openapi": "/api-reference/openapi.json",
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "url": "full",
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript"
      ],
      "defaults": "required",
      "prefill": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "PASCA API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "api/introduction",
              "api/authentication"
            ]
          },
          {
            "group": "Core modules",
            "pages": [
              "api/core/invoices",
              "api/core/irn-and-qr",
              "api/core/transmission",
              "api/core/status-validation"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api/endpoints/resources",
              "api/endpoints/invoices",
              "api/endpoints/irn-qr",
              "api/endpoints/business"
            ]
          },
          {
            "group": "Errors and webhooks",
            "pages": [
              "api/errors",
              "api/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "API reference",
            "pages": [
              "api-reference/introduction",
              "api-reference/all-endpoints"
            ]
          },
          {
            "group": "All endpoints",
            "openapi": "/api-reference/openapi.json"
